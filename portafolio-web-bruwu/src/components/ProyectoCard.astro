---
// ProyectoCard.astro
// Card compacta para el grid de proyectos.
// Al hover: overlay con descripción. Al clic: abre el modal global.

interface Props {
  titulo: string;
  año: string | number;
  descripcion: string;
  tags: string[];
  videoUrl?: string;
  imagenUrl?: string;
  link?: string;
}

const { titulo, año, descripcion, tags, videoUrl, imagenUrl, link } = Astro.props;

// Emoji de engine/plataforma para el placeholder de color
const engineEmoji = tags.includes('Unreal Engine 5') ? '🎮'
  : tags.includes('Unity') ? '⚙️'
  : tags.includes('Roblox') ? '🧱'
  : tags.includes('ServiceNow') ? '🖥️'
  : '📦';
---

<article
  class="card"
  role="button"
  tabindex="0"
  data-modal-titulo={titulo}
  data-modal-video={videoUrl ?? ''}
  data-modal-imagen={imagenUrl ?? ''}
  data-modal-link={link ?? ''}
  data-modal-desc={descripcion}
  data-open-card-modal
  aria-label={`Ver proyecto: ${titulo}`}
>
  <!-- Thumbnail -->
  <div class="card__thumb">
    {
      imagenUrl ? (
        <img src={imagenUrl} alt={titulo} class="card__img" loading="lazy" />
      ) : videoUrl ? (
        <video
          class="card__video"
          src={videoUrl}
          muted
          playsinline
          preload="metadata"
          data-card-video
        />
      ) : (
        <div class="card__placeholder" aria-hidden="true">
          <span>{engineEmoji}</span>
        </div>
      )
    }

    <!-- Overlay hover -->
    <div class="card__overlay" aria-hidden="true">
      <p class="card__overlay-desc">{descripcion}</p>
      <span class="card__overlay-cta">
        {videoUrl ? '▶ Ver demo' : link ? 'Abrir →' : 'Ver más →'}
      </span>
    </div>
  </div>

  <!-- Pie de la card -->
  <div class="card__footer">
    <div class="card__footer-top">
      <h3 class="card__titulo">{titulo}</h3>
      <span class="card__año">{año}</span>
    </div>

    {tags.length > 0 && (
      <ul class="card__tags" aria-label="Tecnologías">
        {tags.slice(0, 3).map((tag) => (
          <li class="card__tag">{tag}</li>
        ))}
        {tags.length > 3 && (
          <li class="card__tag card__tag--more">+{tags.length - 3}</li>
        )}
      </ul>
    )}
  </div>
</article>

<style>
  .card {
    background: var(--color-tarjeta);
    border-radius: var(--radio-md);
    border: 1px solid var(--color-borde);
    box-shadow: var(--sombra-card);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
    outline: none;
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-6px);
    box-shadow: var(--sombra-hover);
  }

  .card:focus-visible {
    outline: 2px solid var(--color-acento);
    outline-offset: 3px;
  }

  /* ── Thumbnail ──────────────────── */
  .card__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #1a1a1a;
    flex-shrink: 0;
  }

  .card__img,
  .card__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s var(--ease-out);
  }

  .card:hover .card__img,
  .card:hover .card__video {
    transform: scale(1.06);
  }

  .card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fff3c4 0%, #ffe082 100%);
    font-size: 2.5rem;
    opacity: 0.6;
  }

  /* ── Overlay ────────────────────── */
  .card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(30, 20, 10, 0.92) 0%,
      rgba(30, 20, 10, 0.6) 50%,
      rgba(30, 20, 10, 0.1) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem 1rem 0.8rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card:hover .card__overlay,
  .card:focus-visible .card__overlay {
    opacity: 1;
  }

  .card__overlay-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.55;
    margin: 0 0 0.5rem;
    /* Limitar a 3 líneas */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__overlay-cta {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-acento);
    letter-spacing: 0.5px;
  }

  /* ── Pie ────────────────────────── */
  .card__footer {
    padding: 0.9rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }

  .card__footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card__titulo {
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-texto);
    line-height: 1.3;
    margin: 0;
    flex: 1;
  }

  .card__año {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-texto-tenue);
    flex-shrink: 0;
    padding-top: 1px;
  }

  /* Tags */
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card__tag {
    padding: 2px 10px;
    border-radius: var(--radio-pill);
    background: var(--color-acento-bg);
    border: 1px solid rgba(255, 213, 79, 0.45);
    color: var(--color-texto);
    font-size: 0.68rem;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
  }

  .card__tag--more {
    background: transparent;
    border-color: var(--color-borde);
    color: var(--color-texto-tenue);
  }
</style>

<script>
  // Preview de video al hover sobre la card
  document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
    const video = card.querySelector<HTMLVideoElement>('[data-card-video]');
    if (!video) return;

    video.addEventListener('loadedmetadata', () => {
      video.currentTime = 1.5;
    });

    card.addEventListener('mouseenter', () => {
      video.play().catch(() => {});
    });

    card.addEventListener('mouseleave', () => {
      video.pause();
      video.currentTime = 1.5;
    });
  });
</script>
