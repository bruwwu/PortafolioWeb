---
import "../styles/global.css";
import ProyectoFeatured from "../components/ProyectoFeatured.astro";
import ProyectoCard from "../components/ProyectoCard.astro";
import MascotaInteractiva from "../components/MascotaInteractiva.astro";
import TopDownRPG from "../components/TopDownRPG.astro";

const proyectos = [
	{
		titulo: "Demo en UE5 — Sistema basado en momentum",
		año: 2025,
		descripcion:
			"Juego en desarrollo basado en mecánicas de movimiento con momentum.",
		tags: ["Unreal Engine 5", "Blueprints", "Third Person", "Movement"],
		videoUrl: "/images/UnrealShowcase.mp4",
		destacado: true,
	},
	{
		titulo: "Showcase — Comportamiento de NPC's",
		año: 2024,
		descripcion:
			"Sistema de diálogos, uso de Terrain y sus brochas, e implementación de pistas de audio para dichos diálogos. Los assets mostrados no son propios y pueden encontrarse en la Unity Asset Store.",
		tags: ["Unity", "C#", "Game AI", "Terrain"],
		videoUrl: "/images/NPCvideo.mp4",
	},
	{
		titulo: "Colaboración — Shaders & Partículas",
		año: 2024,
		descripcion:
			"En colaboración con @_fangfriday, desarrollamos un sistema de partículas de nieve, un shader de agua y un efecto de cámara pixel-art en Unity.",
		tags: ["Unity", "Shaders", "Partículas", "Pixel Art"],
		videoUrl: "/images/ShadersShow.mp4",
	},
	{
		titulo: "Boss Fight — Proyecto IA",
		año: 2024,
		descripcion:
			"Boss fight desarrollada en Unity con sistema de 4 habilidades: salto, melee, proyectiles venenosos y aura de veneno. Incluye mecánica de enemigos laterales que otorgan inmunidad temporal al ser derrotados.",
		tags: ["Unity", "C#", "Game AI", "Boss Design"],
		videoUrl: "/images/bossfightShowcase.mp4",
	},
	{
		titulo: "Camina O Muere — Roblox Experience",
		año: 2025,
		descripcion:
			"Experiencia para Roblox en desarrollo bajo el estudio kiwi procedural. Inspirada en «The Long Walk». El proyecto ya fue lanzado al publico :D",
		tags: ["Roblox", "Lua", "Procedural"],
		imagenUrl: "/images/CaminaOMuere.png",
		link: "https://www.roblox.com/share?code=b63caaebfceffc4eadc8f2a02309b015&type=ExperienceDetails&stamp=1779918549344",
	},

];

const featured = proyectos.find((p) => p.destacado)!;
const resto = proyectos.filter((p) => !p.destacado);
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="bruwuu — Portafolio de Bruno Amezcua Reyna. Desarrollador de videojuegos en Unity y software especializado en ServiceNow."
		/>
		<meta name="author" content="Bruno Amezcua Reyna" />
		<title>bruwuu — Portfolio</title>

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<!-- Fonts: Poppins (títulos) + Inter (cuerpo) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body>
		<!-- ═══════════════════════════
         BANNER
    ═══════════════════════════ -->
		<div class="banner">
			<img
				src="/images/bannerImage.jpg"
				alt="Banner decorativo"
				class="banner__img"
			/>
		</div>

		<!-- ═══════════════════════════
         HERO / PERFIL
    ═══════════════════════════ -->
		<section class="perfil">
			<img
				src="/images/bruwuformal.jpeg"
				alt="Avatar animado — bruwuu"
				class="perfil__avatar"
			/>

			<h1 class="perfil__nombre">bruwwu</h1>
			<p class="perfil__subtitulo">Bruno Amezcua Reyna</p>
			<a
				href="mailto:brunoamezcua1@gmail.com"
				class="perfil__email"
				aria-label="Enviar correo a Bruno">✉️ brunoamezcua1@gmail.com</a
			>

			<p class="perfil__bio">
				Desarrollador de software especializado en el ecosistema
				ServiceNow y programación de videojuegos (C#, Unity).
				Actualmente enfocado en la consultoría tecnológica y la creación
				de experiencias interactivas.
			</p>

			<!-- Iconos sociales -->
			<nav class="social" aria-label="Redes sociales">
				<!-- Instagram -->
				<a
					href="https://www.instagram.com/bruwutuwu/"
					target="_blank"
					rel="noopener"
					aria-label="Instagram"
				>
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
						></path>
					</svg>
				</a>

				<!-- Twitter / X -->
				<a
					href="https://x.com/btuwu91200"
					target="_blank"
					rel="noopener"
					aria-label="Twitter / X"
				>
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.264 5.633L18.243 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"
						></path>
					</svg>
				</a>

				<!-- YouTube -->
				<a
					href="https://www.youtube.com/@bruwu777"
					target="_blank"
					rel="noopener"
					aria-label="YouTube"
				>
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
						></path>
					</svg>
				</a>

				<!-- GitHub -->
				<a
					href="https://github.com/bruwwu"
					target="_blank"
					rel="noopener"
					aria-label="GitHub"
				>
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
						></path>
					</svg>
				</a>

				<!-- LinkedIn -->
				<a
					href="https://www.linkedin.com/in/brun0ar/"
					target="_blank"
					rel="noopener"
					aria-label="LinkedIn"
				>
					<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
						></path>
					</svg>
				</a>
			</nav>
		</section>

		<!-- ═══════════════════════════
         PROYECTOS
    ═══════════════════════════ -->
		<main class="showcase">
			<div class="showcase__inner">
				<!-- Encabezado de sección -->
				<header class="showcase__header">
					<h2 class="showcase__titulo">
						<span>Proyectos <em>&amp;</em> Showcases</span>
					</h2>
					<p class="showcase__subtitulo">
						{proyectos.length} proyectos · Game dev &amp; Software
					</p>
				</header>

				<!-- Proyecto destacado -->
				<section class="showcase__featured" aria-label="Proyecto destacado">
					<ProyectoFeatured
						titulo={featured.titulo}
						año={featured.año}
						descripcion={featured.descripcion}
						tags={featured.tags}
						videoUrl={featured.videoUrl}
						imagenUrl={featured.imagenUrl}
						link={featured.link}
					/>
				</section>

				<!-- Grid del resto -->
				<section class="showcase__grid-wrap" aria-label="Más proyectos">
					<h3 class="showcase__grid-titulo">Más proyectos</h3>
					<div class="showcase__grid" role="list">
						{
							resto.map((p) => (
								<div role="listitem">
									<ProyectoCard
										titulo={p.titulo}
										año={p.año}
										descripcion={p.descripcion}
										tags={p.tags}
										videoUrl={p.videoUrl}
										imagenUrl={p.imagenUrl}
										link={p.link}
									/>
								</div>
							))
						}
					</div>
				</section>

			<!-- Sección jugable — Mini-Juego TopDown -->
			<section class="showcase__playable" aria-label="Mini-juego interactivo">
				<div class="playable__header">
					<h3 class="playable__titulo">🎮 Mini-Juego TopDown — ServiceNow</h3>
					<p class="playable__desc">
						Minijuego de vista top-down desarrollado completamente dentro de la plataforma ServiceNow usando HTML, CSS y JavaScript puro.
						Creado para demostrar habilidades de desarrollo web en un entorno enterprise.
					</p>
					<ul class="playable__tags">
						<li>ServiceNow</li>
						<li>HTML</li>
						<li>CSS</li>
						<li>JavaScript</li>
					</ul>
				</div>
				<TopDownRPG />
			</section>
		</div>
	</main>

		<!-- ═══════════════════════════
         FOOTER
    ═══════════════════════════ -->
		<footer class="footer">
			<p>
				¿Qué se sentirá <strong>saber programar</strong>? &nbsp;·&nbsp;
				<span class="footer__marca">bruwuu</span> © 2025
			</p>
		</footer>

		<!-- ═══════════════════════════
         EASTER EGG — Mascota
    ═══════════════════════════ -->
		<MascotaInteractiva />

		<!-- ═══════════════════════════
         MODAL LIGHTBOX
    ═══════════════════════════ -->
		<div
			class="modal"
			id="proyecto-modal"
			role="dialog"
			aria-modal="true"
			aria-labelledby="modal-titulo"
			hidden
		>
			<div class="modal__backdrop" id="modal-backdrop"></div>
			<div class="modal__box">
				<button
					class="modal__close"
					id="modal-close"
					aria-label="Cerrar modal"
				>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20">
						<path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>

				<div class="modal__media" id="modal-media"></div>

				<div class="modal__info">
					<h3 class="modal__titulo" id="modal-titulo"></h3>
					<p class="modal__desc" id="modal-desc"></p>
					<a class="modal__link" id="modal-link" href="#" target="_blank" rel="noopener noreferrer" hidden>
						Abrir proyecto →
					</a>
				</div>
			</div>
		</div>
	</body>
</html>

<style>
	/* ── Banner ─────────────────────────── */
	.banner {
		position: relative;
		width: 100%;
		height: 260px;
		overflow: hidden;
		background: #fff3c4;
	}

	.banner::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(255, 249, 230, 0) 0%,
			rgba(255, 249, 230, 0.55) 70%,
			rgba(255, 249, 230, 1) 100%
		);
		pointer-events: none;
	}

	.banner__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.92) saturate(0.85);
	}

	/* ── Perfil ─────────────────────────── */
	.perfil {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 0 2rem 3rem;
		background: var(--color-fondo);
		position: relative;
		z-index: 2;
	}

	.perfil__avatar {
		width: 130px;
		height: 130px;
		border-radius: 50%;
		margin-top: -65px;
		border: 5px solid var(--color-fondo);
		outline: 3px solid var(--color-acento);
		object-fit: cover;
		background: #fff3c4;
		box-shadow: 0 4px 24px rgba(74, 53, 37, 0.15);
		transition:
			transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.4s ease;
	}

	.perfil__avatar:hover {
		transform: scale(1.06) rotate(2deg);
		box-shadow: 0 8px 36px rgba(249, 168, 37, 0.35);
	}

	.perfil__nombre {
		margin-top: 1.25rem;
		letter-spacing: -0.5px;
	}

	.perfil__subtitulo {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-texto-tenue, #9e8878);
		font-family: "Inter", sans-serif;
		margin-top: 0.3rem;
	}

	.perfil__email {
		display: inline-block;
		margin-top: 0.45rem;
		font-family: "Inter", sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--color-texto-tenue, #9e8878);
		text-decoration: none;
		border-bottom: 1.5px dashed rgba(74, 53, 37, 0.25);
		padding-bottom: 1px;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.perfil__email:hover {
		color: #f9a825;
		border-color: #f9a825;
	}

	.perfil__bio {
		max-width: 560px;
		margin: 1rem auto 0;
		font-size: 0.95rem;
		color: var(--color-texto-suave, #7a6555);
		line-height: 1.8;
	}

	/* ── Social icons ──────────────────── */
	.social {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.25rem;
		margin-top: 1.75rem;
	}

	.social a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		color: var(--color-texto);
		background: transparent;
		border: 1.5px solid rgba(74, 53, 37, 0.12);
		transition:
			color 0.25s ease,
			background 0.25s ease,
			border-color 0.25s ease,
			transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.3s ease;
	}

	.social a svg {
		width: 20px;
		height: 20px;
		fill: currentColor;
	}

	.social a:hover {
		color: var(--color-texto);
		background: var(--color-acento);
		border-color: var(--color-acento);
		transform: translateY(-4px);
		box-shadow: 0 4px 14px rgba(249, 168, 37, 0.35);
	}

	/* ── Showcase (contenedor principal) ── */
	.showcase {
		background: var(--color-fondo);
		padding: 0 1.5rem 5rem;
	}

	.showcase__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	/* Encabezado */
	.showcase__header {
		text-align: center;
		padding-top: 3rem;
	}

	.showcase__titulo {
		font-family: "Poppins", sans-serif;
		font-weight: 700;
		font-size: clamp(1.35rem, 3vw, 1.9rem);
		color: var(--color-texto);
		position: relative;
		display: inline-block;
	}

	.showcase__titulo span {
		position: relative;
	}

	.showcase__titulo span::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -6px;
		width: 100%;
		height: 4px;
		background: var(--color-acento);
		border-radius: var(--radio-pill);
	}

	.showcase__titulo em {
		font-style: normal;
		color: var(--color-acento);
	}

	.showcase__subtitulo {
		margin-top: 1rem;
		font-size: 0.88rem;
		color: var(--color-texto-tenue);
		font-family: "Inter", sans-serif;
		font-weight: 500;
		letter-spacing: 0.5px;
	}

	/* Grid de cards */
	.showcase__grid-titulo {
		font-family: "Poppins", sans-serif;
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-texto-suave);
		margin-bottom: 1.25rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.showcase__grid-titulo::after {
		content: "";
		flex: 1;
		height: 1px;
		background: var(--color-borde);
	}

	.showcase__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	/* ── Playable Section ─────────────── */
	.showcase__playable {
		background: #1a1a1a;
		border-radius: var(--radio-lg, 16px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		overflow: hidden;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.25);
	}

	.playable__header {
		padding: 2rem 2rem 0;
		text-align: center;
	}

	.playable__titulo {
		font-family: "Poppins", sans-serif;
		font-size: 1.15rem;
		font-weight: 700;
		color: #fff;
		margin: 0 0 0.75rem;
	}

	.playable__desc {
		font-size: 0.88rem;
		color: #bdc3c7;
		line-height: 1.7;
		max-width: 600px;
		margin: 0 auto 1rem;
	}

	.playable__tags {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		padding: 0;
		margin: 0 0 0.5rem;
	}

	.playable__tags li {
		padding: 3px 12px;
		border-radius: var(--radio-pill, 50px);
		background: rgba(249, 168, 37, 0.15);
		border: 1px solid rgba(249, 168, 37, 0.35);
		color: #f9a825;
		font-size: 0.7rem;
		font-weight: 600;
		font-family: "Poppins", sans-serif;
	}

	/* ── Footer ────────────────────────── */
	.footer {
		text-align: center;
		padding: 2rem;
		background: #ffffff;
		border-top: 1px solid rgba(74, 53, 37, 0.08);
		color: #9e8878;
		font-size: 0.875rem;
		font-family: "Inter", sans-serif;
	}

	.footer strong {
		color: var(--color-texto);
		font-weight: 600;
	}
	.footer__marca {
		color: #f9a825;
	}

	/* ── Modal Lightbox ─────────────────── */
	.modal {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
	}

	.modal[hidden] {
		display: none;
	}

	.modal__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(30, 20, 10, 0.82);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		cursor: pointer;
	}

	.modal__box {
		position: relative;
		z-index: 1;
		background: var(--color-tarjeta);
		border-radius: var(--radio-lg);
		max-width: 860px;
		width: 100%;
		overflow: hidden;
		box-shadow: 0 24px 80px rgba(30, 20, 10, 0.45);
		animation: modal-in 0.3s var(--ease-out) both;
	}

	@keyframes modal-in {
		from {
			opacity: 0;
			transform: scale(0.94) translateY(12px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}

	.modal__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 10;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid var(--color-borde);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-texto);
		transition:
			background 0.2s ease,
			transform 0.2s ease;
	}

	.modal__close:hover {
		background: var(--color-acento);
		transform: scale(1.08);
	}

	.modal__media {
		width: 100%;
		aspect-ratio: 16 / 9;
		background: #111;
		overflow: hidden;
	}

	.modal__media video,
	.modal__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.modal__info {
		padding: 1.5rem 1.75rem 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.modal__titulo {
		font-family: "Poppins", sans-serif;
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-texto);
		margin: 0;
	}

	.modal__desc {
		font-size: 0.9rem;
		color: var(--color-texto-suave);
		line-height: 1.75;
		margin: 0;
	}

	.modal__link {
		display: inline-block;
		margin-top: 0.25rem;
		font-family: "Poppins", sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		color: #f9a825;
		text-decoration: none;
	}
	.modal__link:hover {
		color: var(--color-texto);
	}
	.modal__link[hidden] {
		display: none;
	}

	/* ── Responsive ────────────────────── */
	@media (max-width: 900px) {
		.showcase__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 700px) {
		.banner {
			height: 180px;
		}

		.perfil__avatar {
			width: 110px;
			height: 110px;
			margin-top: -55px;
		}

		.social {
			gap: 0.85rem;
		}

		.showcase {
			padding: 0 1rem 4rem;
		}

		.showcase__grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	// ── Modal Lightbox ──────────────────────────────────────────
	const modal = document.getElementById('proyecto-modal') as HTMLElement;
	const modalMedia = document.getElementById('modal-media') as HTMLElement;
	const modalTitulo = document.getElementById('modal-titulo') as HTMLElement;
	const modalDesc = document.getElementById('modal-desc') as HTMLElement;
	const modalLink = document.getElementById('modal-link') as HTMLAnchorElement;
	const modalClose = document.getElementById('modal-close') as HTMLButtonElement;
	const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement;

	function openModal(data: {
		titulo: string;
		desc: string;
		video?: string;
		imagen?: string;
		link?: string;
	}) {
		// Limpiar media anterior
		modalMedia.innerHTML = '';

		if (data.video) {
			const v = document.createElement('video');
			v.src = data.video;
			v.controls = true;
			v.autoplay = true;
			v.muted = false;
			v.style.width = '100%';
			v.style.height = '100%';
			v.style.objectFit = 'cover';
			modalMedia.appendChild(v);
		} else if (data.imagen) {
			const img = document.createElement('img');
			img.src = data.imagen;
			img.alt = data.titulo;
			modalMedia.appendChild(img);
		}

		modalTitulo.textContent = data.titulo;
		modalDesc.textContent = data.desc;

		if (data.link) {
			modalLink.href = data.link;
			modalLink.removeAttribute('hidden');
		} else {
			modalLink.setAttribute('hidden', '');
		}

		modal.removeAttribute('hidden');
		document.body.style.overflow = 'hidden';
		modalClose.focus();
	}

	function closeModal() {
		modal.setAttribute('hidden', '');
		document.body.style.overflow = '';
		// Detener video si hay
		const v = modalMedia.querySelector('video');
		if (v) {
			v.pause();
			v.src = '';
		}
		modalMedia.innerHTML = '';
	}

	// Botón CTA del featured (data-open-modal)
	document.querySelectorAll<HTMLButtonElement>('[data-open-modal]').forEach((btn) => {
		btn.addEventListener('click', () => {
			openModal({
				titulo: btn.dataset.modalTitulo ?? '',
				desc: '',
				video: btn.dataset.modalVideo || undefined,
			});
		});
	});

	// Cards del grid (data-open-card-modal)
	document.querySelectorAll<HTMLElement>('[data-open-card-modal]').forEach((card) => {
		const open = () => {
			const link = card.dataset.modalLink;
			// Si tiene link externo y NO tiene video, abre directamente
			if (link && !card.dataset.modalVideo) {
				window.open(link, '_blank', 'noopener,noreferrer');
				return;
			}
			openModal({
				titulo: card.dataset.modalTitulo ?? '',
				desc: card.dataset.modalDesc ?? '',
				video: card.dataset.modalVideo || undefined,
				imagen: card.dataset.modalImagen || undefined,
				link: link || undefined,
			});
		};

		card.addEventListener('click', open);
		card.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				open();
			}
		});
	});

	// Cerrar modal
	modalClose.addEventListener('click', closeModal);
	modalBackdrop.addEventListener('click', closeModal);
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
	});
</script>
